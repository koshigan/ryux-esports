# ─────────────────────────────────────────
# AUCTION APP - ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# ─────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Database (MySQL) - Update with your Aiven credentials from Aiven Console
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=17460
DB_USER=your-aiven-username
DB_PASS=your-aiven-password
DB_NAME=defaultdb

# Session secret (change to a long random string)
SESSION_SECRET=change-this-to-something-long-and-random-abc123xyz

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
